## FiveM Documentation
## https://aka.cfx.re/server-commands

## QBCore Documentation
## https://docs.qbcore.org

## Kurulum: Bu dosyayı server.cfg olarak kopyalayın ve aşağıdaki placeholder'ları doldurun.
##   copy server.cfg.example server.cfg

## You CAN edit the following:
endpoint_add_tcp "0.0.0.0:30120"
endpoint_add_udp "0.0.0.0:30120"
sv_maxclients 32
set steam_webApiKey "YOUR_STEAM_WEB_API_KEY"
sets tags "hardrp, textrp, qbcore, turkish"

## You MAY edit the following:
sv_licenseKey "YOUR_CFX_LICENSE_KEY"
sv_hostname "Hard RP Text-Based Sunucu"
sets sv_projectName "Hard RP"
sets sv_projectDesc "Text-based hard roleplay — QBCore tabanlı"
sets locale "tr-TR"
load_server_icon myLogo.png
sv_enforceGameBuild 3095
set resources_useSystemChat true
set mysql_connection_string "mysql://USER:PASSWORD@localhost/DATABASE?charset=utf8mb4"

# Güvenlik
sv_scriptHookAllowed 0
#set sv_authMaxVariance 1
#set sv_authMinTrust 5

# OneSync (slot sayısına göre ayarlayın)
## set onesync on

# Text-based RP — ses altyapısı bilinçli olarak kapalı (pma-voice / qb-radio yüklenmez)

# QBCore
setr qb_locale "tr"
setr UseTarget false
setr qb_whitelist 0
# Kapalı beta / açılış öncesi: 1 yapın ve aşağıdaki ACE whitelist'i doldurun
sets qb_discord "https://discord.gg/DEGISTIR"

# Toast → rp-chat (opsiyonel, qb-smallresources ile uyumlu)
setr qb_notify_to_chat true

# --- CFX varsayılan ---
ensure mapmanager
ensure chat
ensure spawnmanager
ensure sessionmanager
ensure basic-gamemode
ensure hardcap
ensure baseevents

# --- Bağımlılıklar (explicit — [standalone] klasörü toplu yüklenmez) ---
ensure oxmysql
ensure connectqueue
ensure PolyZone
ensure progressbar
ensure interact-sound
ensure bob74_ipl
ensure menuv

# --- QBCore çekirdek ---
ensure qb-core
ensure qb-multicharacter
ensure qb-spawn
ensure qb-loading
ensure qb-clothing
ensure qb-input
ensure qb-menu
ensure qb-inventory
ensure qb-weapons
ensure qb-banking
ensure qb-smallresources
ensure qb-weathersync
ensure qb-doorlock
ensure qb-target
ensure qb-vehiclekeys
ensure qb-garages
ensure qb-fuel
ensure qb-policejob
ensure qb-ambulancejob
ensure qb-adminmenu
ensure qb-hud

# --- Hard RP custom ---
ensure rp-chat
ensure rp-ignition
ensure rp-mileage
ensure rp-dealership

# --- Haritalar ---
ensure dealer_map
ensure hospital_map
ensure prison_main
ensure prison_canteen
ensure prison_meeting

# NOT: Arcade scriptler (soygun, drugs, crypto, qb-phone vb.) bilinçli olarak
# bu listede yok. qb-shops da kapalı — NPC'li 24/7 mağaza hard RP ile uyumsuz.
# İhtiyaç halinde tek tek ekleyin — docs/ROADMAP.md

## Permissions ##
add_ace group.admin command allow
add_principal identifier.fivem:YOUR_FIVEM_ID group.admin

add_ace resource.qb-core command allow
add_ace qbcore.god command allow

add_principal qbcore.god group.admin
add_principal qbcore.god qbcore.admin
add_principal qbcore.admin qbcore.mod

# Whitelist (setr qb_whitelist 1 iken)
add_ace group.admin join allow
add_ace group.whitelisted join allow
# add_principal identifier.license:ROCKSTAR_LICENSE group.whitelisted
